# From Supabase Dashboard > Connect dialog, or Settings > API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# --- AI Configuration ---
# Provider: "openai", "venice", "openrouter", or any OpenAI-compatible service
AI_PROVIDER=venice
AI_API_KEY=your-api-key-here

# Models — use the model IDs from your provider
# Venice examples: llama-3.3-70b, mistral-31-24b, deepseek-ai-DeepSeek-R1, gpt-4o
# OpenAI examples: gpt-4o-mini, gpt-4o-2024-08-06
# OpenRouter examples: meta-llama/llama-3.1-70b-instruct, mistralai/mistral-large-latest
AI_MODEL_LEVEL1=llama-3.3-70b
AI_MODEL_LEVEL2=llama-3.3-70b
AI_MODEL_EXTRACTION=llama-3.3-70b

# Optional: override the base URL (auto-set for venice/openrouter)
# AI_BASE_URL=https://api.venice.ai/api/v1

# Legacy (still works): if you set OPENAI_API_KEY it will be used as AI_API_KEY
# OPENAI_API_KEY=sk-...

# Optional: for multi-LLM benchmarking (eval/benchmark_models.py)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...

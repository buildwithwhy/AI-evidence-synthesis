# From Supabase Dashboard > Connect dialog, or Settings > API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# --- AI Configuration ---
# OpenRouter API key (primary — gives access to all models)
OPENROUTER_API_KEY=sk-or-...

# Screening strategy: single, same_model_dual, mixed_model
SCREENING_STRATEGY=mixed_model

# Models for screening (names from the model registry)
# Free tier default: Llama (high sensitivity) + DeepSeek (high specificity)
SCREENING_MODEL_A=llama-3.3-70b
SCREENING_MODEL_B=deepseek-v3

# For institutional tier: Claude with dual-run
# SCREENING_STRATEGY=same_model_dual
# SCREENING_MODEL_A=claude-sonnet-4.6
# SCREENING_MODEL_B=claude-sonnet-4.6

# Legacy (still works for PICO extraction and mining)
# AI_API_KEY=your-key
# AI_PROVIDER=openrouter
